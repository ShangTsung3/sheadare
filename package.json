  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n fe,be -c blue,green \"vite --port=3000 --host=0.0.0.0\" \"tsx watch server/index.ts\"",
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "dev:backend": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:seed": "tsx server/db/seed.ts",
    "scrape:discover": "tsx server/jobs/run-discover.ts",
    "scrape:spar": "tsx server/jobs/run-discover.ts spar",
    "scrape:nabiji": "tsx server/jobs/run-discover.ts nabiji",
    "scrape:goodwill": "tsx server/jobs/run-discover.ts goodwill"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/leaflet": "^1.9.21",
